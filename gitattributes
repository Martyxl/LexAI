# Všechny textové soubory — CRLF na Windows
* text=auto eol=crlf

# Explicitně textové soubory
*.html    text eol=crlf
*.js      text eol=crlf
*.json    text eol=crlf
*.md      text eol=crlf
*.txt     text eol=crlf
*.env*    text eol=crlf

# Binární soubory — beze změny
*.pdf     binary
*.png     binary
*.jpg     binary
*.ico     binary

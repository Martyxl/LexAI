# ── Povinné ──────────────────────────────────────────────────────────────────
# Anthropic API klíč (získáš na console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel KV (Redis) — nastavíš přes Vercel Dashboard → Storage → Create KV ─
# Tyto proměnné se automaticky přidají po propojení KV databáze s projektem:
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ── Admin panel ───────────────────────────────────────────────────────────────
# Přístup na /admin?token=<tento_token>
ADMIN_TOKEN=zmenme_toto_na_neco_silneho_123
